{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build godot-launcher",
            "type": "shell",
            "command": "./scripts/build_godot_launcher.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": false
            },
            "problemMatcher": "$rustc"
        }
    ]
}
