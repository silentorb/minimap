# Copy to a file outside the repo (e.g. ~/.config/godot-launcher.env) and export before starting.
# Never commit real tokens.

GODOT_LAUNCHER_TOKEN=replace-with-long-random-secret
GODOT_LAUNCHER_GODOT_EXE=/mnt/c/Apps/Godot/Godot_v4.6-stable_win64.exe
GODOT_LAUNCHER_ALLOWLIST_PREFIXES=/workspaces/minimap,/mnt/c/dev/games/minimap
GODOT_LAUNCHER_LISTEN=127.0.0.1:27182

# Optional: map dev-container /workspaces/... to a Windows checkout Godot understands:
# GODOT_LAUNCHER_WORKSPACE_LINUX=/workspaces/minimap
# GODOT_LAUNCHER_WORKSPACE_WINDOWS=C:\dev\games\minimap
