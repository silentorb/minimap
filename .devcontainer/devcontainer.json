{
    "name": "minimap",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/dotnet:2": {
            "version": "8.0",
            "dotnetRuntimeVersions": "8.0"
        }
    },
    "containerEnv": {
        "GODOT_REMOTE_URL": "http://127.0.0.1:27182",
        "GODOT_REMOTE_TOKEN": "${localEnv:GODOT_REMOTE_TOKEN}",
        "CARGO_TARGET_DIR": "/workspaces/build/cargo-target"
    },
    "postCreateCommand": "./scripts/build_godot_launcher.sh",
    "runArgs": [
        "--network=host"
    ],
    "mounts": [
    ],
    "customizations": {
        "vscode": {
            "extensions": [],
            "settings": {
                "files.eol": "\n"
            }
        }
    }
}