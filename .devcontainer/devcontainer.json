{
    "name": "minimap",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "runArgs": [
        "--network=host"
    ],
    "features": {
        "ghcr.io/danzilberdan/devcontainers/opencode:0": {}
    },
    "initializeCommand": "mkdir -p ${localEnv:HOME}/.config/opencode",
    "mounts": [
        "source=${localEnv:HOME}/.config/opencode,target=/home/vscode/.config/opencode,type=bind",
        // Temporary: Unreal marloth source from host; remove or retarget when paths settle.
        "source=/mnt/e/dev/games/marloth/Source,target=${containerWorkspaceFolder}/.mnt/unreal/marloth,type=bind,readonly"
    ],
    "customizations": {
        "vscode": {
            "extensions": []
        }
    },
    "containerEnv": {
        "OLLAMA_HOST": "http://host.docker.internal:11434"
    }
}